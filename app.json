{
  "expo": {
    "name": "MythicMath",
    "slug": "mythicmath-front",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "splash": {
      "image": "./assets/images/splash-mythic.png",
      "resizeMode": "contain",
      "backgroundColor": "#140c24"
    },
    "scheme": "mythicmathfront",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.mythicmathfront"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.jpeg"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
